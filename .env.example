# =============================================================================
# VITA STRATEGIES - ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to create environment-specific .env files
# Never commit actual passwords to Git!
# =============================================================================

# Domain Configuration
DOMAIN=your-domain.com
ENVIRONMENT=development
EXTERNAL_IP=your-server-ip

# Cloudflare Configuration (get from Cloudflare dashboard)
CLOUDFLARE_EMAIL=your-email@domain.com
CLOUDFLARE_API_KEY=your-cloudflare-api-key

# Database Configuration (generate secure passwords)
MYSQL_ROOT_PASSWORD=your-mysql-root-password
POSTGRES_PASSWORD=your-postgres-password
REDIS_PASSWORD=your-redis-password

# ERPNext Configuration
FRAPPE_SITE_NAME=erp.your-domain.com
FRAPPE_ADMIN_PASSWORD=your-erpnext-password

# Keycloak Authentication
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=your-keycloak-password

# Windmill Workflow Automation
WINDMILL_ADMIN_USER=admin
WINDMILL_ADMIN_PASSWORD=your-windmill-password

# Mattermost Team Communication
MATTERMOST_ADMIN_USER=admin
MATTERMOST_ADMIN_PASSWORD=your-mattermost-password

# Grafana Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# Metabase Analytics
METABASE_ADMIN_USER=admin
METABASE_ADMIN_PASSWORD=your-metabase-password

# Appsmith App Builder
APPSMITH_ADMIN_USER=admin
APPSMITH_ADMIN_PASSWORD=your-appsmith-password

# Openbao Secrets Management
OPENBAO_ADMIN_USER=admin
OPENBAO_ADMIN_PASSWORD=your-openbao-password

# Security Configuration
SSL_EMAIL=your-email@domain.com
ENABLE_SSL=true
SESSION_TIMEOUT=3600
MAX_FILE_SIZE=50M
RATE_LIMIT_REQUESTS=100

# Generate secure passwords using:
# openssl rand -base64 32
