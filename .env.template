# VITA STRATEGIES ENVIRONMENT TEMPLATE
# Copy this file to .env and replace placeholders with actual values

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<SECURE_POSTGRES_PASSWORD>
POSTGRES_DB=postgres

MARIADB_ROOT_PASSWORD=<SECURE_MARIADB_ROOT_PASSWORD>
MARIADB_DATABASE=wordpress
MARIADB_USER=wordpress
MARIADB_PASSWORD=<SECURE_WORDPRESS_DB_PASSWORD>

# Application Database URLs
WORDPRESS_DB_HOST=mariadb
ERPNEXT_DB_HOST=mariadb
MATTERMOST_DB_URL=postgres://mattermost:<MATTERMOST_DB_PASSWORD>@postgres:5432/mattermost?sslmode=disable
METABASE_DB_URL=postgres://metabase:<METABASE_DB_PASSWORD>@postgres:5432/metabase
GRAFANA_DB_URL=postgres://grafana:<GRAFANA_DB_PASSWORD>@postgres:5432/grafana
KEYCLOAK_DB_URL=postgres://keycloak:<KEYCLOAK_DB_PASSWORD>@postgres:5432/keycloak
APPSMITH_DB_URL=postgres://appsmith:<APPSMITH_DB_PASSWORD>@postgres:5432/appsmith

# SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
SSL_DHPARAM_PATH=/etc/nginx/ssl/dhparam.pem

# Application URLs
WORDPRESS_URL=https://vitastrategies.com
ERPNEXT_URL=https://erp.vitastrategies.com
MATTERMOST_URL=https://chat.vitastrategies.com
METABASE_URL=https://analytics.vitastrategies.com
GRAFANA_URL=https://monitoring.vitastrategies.com
KEYCLOAK_URL=https://auth.vitastrategies.com
APPSMITH_URL=https://apps.vitastrategies.com
OPENBAO_URL=https://vault.vitastrategies.com

# Application Secrets
APPSMITH_ENCRYPTION_PASSWORD=<SECURE_APPSMITH_ENCRYPTION_PASSWORD>
APPSMITH_ENCRYPTION_SALT=<SECURE_APPSMITH_ENCRYPTION_SALT>
KEYCLOAK_ADMIN_PASSWORD=<SECURE_KEYCLOAK_ADMIN_PASSWORD>
OPENBAO_ROOT_TOKEN=<SECURE_OPENBAO_ROOT_TOKEN>

# Storage Paths
WORDPRESS_DATA_PATH=/mnt/buckets/wordpress
ERPNEXT_DATA_PATH=/mnt/buckets/erpnext
MATTERMOST_DATA_PATH=/mnt/buckets/mattermost
METABASE_DATA_PATH=/mnt/buckets/analytics
GRAFANA_DATA_PATH=/mnt/buckets/monitoring
KEYCLOAK_DATA_PATH=/mnt/buckets/auth
APPSMITH_DATA_PATH=/mnt/buckets/appsmith
OPENBAO_DATA_PATH=/mnt/buckets/vault

# Monitoring
GRAFANA_ADMIN_PASSWORD=<SECURE_GRAFANA_ADMIN_PASSWORD>
METABASE_ADMIN_EMAIL=admin@vitastrategies.com
METABASE_ADMIN_PASSWORD=<SECURE_METABASE_ADMIN_PASSWORD>

# Redis Configuration
REDIS_PASSWORD=<SECURE_REDIS_PASSWORD>