# Copy this file to terraform.tfvars and fill in your actual values
# NEVER commit terraform.tfvars to version control

project_id = "your-gcp-project-id"
region     = "europe-west2"
zone       = "europe-west2-c"

# Security - Replace with your actual values
cloudflare_api_token = "your-cloudflare-api-token"
admin_ip             = "your-public-ip/32"
user_ip              = "your-public-ip/32"

# Database passwords - Generate strong passwords
database_passwords = {
  mattermost = "generate-strong-password-here"
  windmill   = "generate-strong-password-here"
  metabase   = "generate-strong-password-here"
  grafana    = "generate-strong-password-here"
  openbao    = "generate-strong-password-here"
  keycloak   = "generate-strong-password-here"
  wordpress  = "generate-strong-password-here"
  bookstack  = "generate-strong-password-here"
  erpnext    = "generate-strong-password-here"
  appsmith   = "generate-strong-password-here"
}

# SSH Keys - Replace with your actual SSH public key
ssh_public_key = "your-ssh-public-key-here"
