# =============================================================================
# VITA STRATEGIES PLATFORM - PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# IMPORTANT: Change all passwords and secrets before production deployment!
# Generate secure passwords using: openssl rand -base64 32
# =============================================================================

# Domain Configuration
DOMAIN=your-domain.com
ENVIRONMENT=production

# Database Configuration
POSTGRES_PASSWORD=your-super-secure-postgres-password-change-this
REDIS_PASSWORD=your-super-secure-redis-password-change-this

# Keycloak Authentication
KEYCLOAK_HOSTNAME=your-domain.com
KEYCLOAK_ADMIN_PASSWORD=your-super-secure-keycloak-admin-password-change-this
KEYCLOAK_APPSMITH_CLIENT_ID=appsmith
KEYCLOAK_APPSMITH_CLIENT_SECRET=your-keycloak-appsmith-client-secret

# Appsmith Configuration
APPSMITH_ENCRYPTION_PASSWORD=your-super-secure-appsmith-encryption-password-change-this
APPSMITH_ENCRYPTION_SALT=your-super-secure-appsmith-salt-change-this
APPSMITH_SUPERVISOR_PASSWORD=your-super-secure-appsmith-supervisor-password-change-this

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=your-super-secure-grafana-admin-password-change-this

# Email/SMTP Configuration
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@your-domain.com

# SSL Configuration
SSL_EMAIL=admin@your-domain.com
ENABLE_SSL=true

# Backup Configuration
BACKUP_ENCRYPTION_KEY=your-super-secure-backup-encryption-key-change-this
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=2555   # 7 years for healthcare compliance

# Monitoring Configuration
MONITORING_EMAIL=admin@your-domain.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
MATTERMOST_WEBHOOK_URL=https://your-domain.com/mattermost/hooks/YOUR_WEBHOOK_ID

# Security Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
SESSION_TIMEOUT=3600
MAX_FILE_SIZE=50M

# Performance Configuration
POSTGRES_MAX_CONNECTIONS=200
REDIS_MAX_MEMORY=512mb
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# Logging Configuration
LOG_LEVEL=info
LOG_MAX_SIZE=100m
LOG_MAX_FILES=10

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_BACKUPS=true
ENABLE_MONITORING=true
ENABLE_SSL_RENEWAL=true

# =============================================================================
# DEVELOPMENT OVERRIDES (commented out for production)
# =============================================================================
# Uncomment for development environment
# POSTGRES_PASSWORD=devpassword
# REDIS_PASSWORD=devpassword
# KEYCLOAK_ADMIN_PASSWORD=admin123
# DOMAIN=localhost
# ENABLE_SSL=false
